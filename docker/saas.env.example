# ============================================================
# Argus SaaS — Environment Variables
# ============================================================
#
# Copy this file to the repo root as .env.saas and fill in values:
#   cp docker/saas.env.example .env.saas
#
# Then start:
#   docker compose -f docker/docker-compose.saas.yml --env-file .env.saas up -d
# ============================================================

# ---- LLM Provider ----
ARGUS_LLM_PROVIDER=openai
ARGUS_LLM_API_KEY=sk-your-api-key-here
ARGUS_LLM_MODEL=gpt-4o

# ---- Deployment ----
# Agent mode: "full" (host monitoring) or "sdk_only" (SDK telemetry only)
ARGUS_MODE=sdk_only

# Version tag to pull from GHCR (default: latest)
# ARGUS_VERSION=latest

# Number of API server processes (uvicorn workers)
ARGUS_API_WORKERS=2

# Number of agent worker replicas
ARGUS_WORKER_REPLICAS=1

# Nginx proxy port (external-facing)
ARGUS_PROXY_PORT=80

# Frontend URL (for email links, Google/GitHub OAuth redirects)
# Where users access the web UI in their browser
ARGUS_FRONTEND_URL=http://localhost:3000

# External API base URL (for Slack OAuth callback, Polar webhooks)
# Your ngrok/public HTTPS URL that reaches nginx/API. Leave empty to use FRONTEND_URL.
ARGUS_API_BASE_URL=

# Debug mode (verbose logging)
ARGUS_DEBUG=false

# ---- Security ----
# JWT signing key — generate with: openssl rand -hex 32
# If left empty, auto-generated on first start and persisted to /data/.secret_key
ARGUS_SECRET_KEY=

# ---- PostgreSQL (operational data) ----
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus

# ---- TimescaleDB (metrics) ----
TIMESCALE_USER=argus
TIMESCALE_PASSWORD=argus
TIMESCALE_DB=argus_metrics

# ---- Billing (Polar.sh) ----
# Leave empty to disable billing features
ARGUS_POLAR_ACCESS_TOKEN=
ARGUS_POLAR_WEBHOOK_SECRET=

# Product IDs — one per plan x interval (monthly & annual)
ARGUS_POLAR_TEAMS_PRODUCT_ID=
ARGUS_DEPLOYMENT__POLAR_TEAMS_ANNUAL_PRODUCT_ID=
ARGUS_DEPLOYMENT__POLAR_BUSINESS_PRODUCT_ID=
ARGUS_DEPLOYMENT__POLAR_BUSINESS_ANNUAL_PRODUCT_ID=

# Prepaid credits — Polar product ID for credit top-ups
ARGUS_DEPLOYMENT__POLAR_PAYG_CREDITS_PRODUCT_ID=
# Override PAYG rate (cents per 1K events, default 30 = $0.30)
# ARGUS_DEPLOYMENT__PAYG_RATE_CENTS_PER_1K=30

# DEPRECATED: metered billing replaced by prepaid credits
# ARGUS_DEPLOYMENT__POLAR_PAYG_METER_ID=

# ---- Email (Resend API) ----
# Primary email transport in SaaS mode; falls back to SMTP if unavailable
ARGUS_DEPLOYMENT__RESEND_API_KEY=
ARGUS_DEPLOYMENT__EMAIL_FROM=Argus <noreply@argus.dev>

# ---- Email (SMTP fallback) ----
# Used if Resend is not configured or fails
# Format: smtp://user:pass@host:port or smtps://user:pass@host:port
ARGUS_DEPLOYMENT__SMTP_URL=

# ---- OAuth (Google) ----
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URI: {ARGUS_FRONTEND_URL}/login/callback/google
ARGUS_DEPLOYMENT__GOOGLE_CLIENT_ID=
ARGUS_DEPLOYMENT__GOOGLE_CLIENT_SECRET=

# ---- OAuth (GitHub) ----
# Create at https://github.com/settings/developers
# Callback URL: {ARGUS_FRONTEND_URL}/login/callback/github
ARGUS_DEPLOYMENT__GITHUB_CLIENT_ID=
ARGUS_DEPLOYMENT__GITHUB_CLIENT_SECRET=

# ---- Slack App (OAuth bot integration) ----
# Create a Slack App at https://api.slack.com/apps
# Set OAuth redirect URL to: {ARGUS_FRONTEND_URL}/api/v1/integrations/slack/callback
ARGUS_DEPLOYMENT__SLACK_CLIENT_ID=
ARGUS_DEPLOYMENT__SLACK_CLIENT_SECRET=
ARGUS_DEPLOYMENT__SLACK_SIGNING_SECRET=
